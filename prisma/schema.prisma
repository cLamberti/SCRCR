generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id               Int       @id @default(autoincrement())
  username         String    @unique @db.VarChar(50)
  email            String    @unique @db.VarChar(255)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  nombreCompleto   String    @map("nombre_completo") @db.VarChar(255)
  rol              String    @default("tesorero") @db.VarChar(20)
  estado           Int       @default(1)
  ultimoAcceso     DateTime? @map("ultimo_acceso")
  intentosFallidos Int       @default(0) @map("intentos_fallidos")
  bloqueadoHasta   DateTime? @map("bloqueado_hasta")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  permisos         Permiso[]

  @@map("usuarios")
}

model Congregado {
  id                Int                 @id @default(autoincrement())
  nombre            String              @db.VarChar(100)
  cedula            String              @unique @db.VarChar(20)
  fechaIngreso      DateTime            @default(now()) @map("fecha_ingreso")
  telefono          String              @db.VarChar(20)
  segundoTelefono   String?             @map("segundo_telefono") @db.VarChar(20)
  estadoCivil       String              @map("estado_civil") @db.VarChar(20)
  ministerio        String              @db.VarChar(50)
  segundoMinisterio String?             @map("segundo_ministerio") @db.VarChar(50)
  urlFotoCedula     String              @map("url_foto_cedula")
  estado            Int                 @default(1) @db.SmallInt
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at")
  correo            String?             @db.VarChar(100)
  direccion         String?
  fechaNacimiento   DateTime?           @map("fecha_nacimiento")
  observaciones     String?
  profesion         String?             @db.VarChar(100)
  reportes          ReporteAsistencia[]

  @@map("congregados")
}

model Asociado {
  id                      Int                 @id @default(autoincrement())
  nombreCompleto          String              @map("nombre_completo") @db.VarChar(100)
  cedula                  String              @unique @db.VarChar(20)
  correo                  String?             @db.VarChar(100)
  telefono                String?             @db.VarChar(20)
  telefonoContacto        String?             @map("telefono_contacto") @db.VarChar(20)
  ministerio              String?             @db.VarChar(50)
  direccion               String?
  fechaIngreso            DateTime            @default(now()) @map("fecha_ingreso")
  fechaNacimiento         DateTime?           @map("fecha_nacimiento")
  estadoCivil             String?             @map("estado_civil") @db.VarChar(30)
  profesion               String?             @db.VarChar(100)
  anosCongregarse         Int?                @map("anos_congregarse")
  fechaAceptacion         DateTime?           @map("fecha_aceptacion")
  perteneceJuntaDirectiva Boolean             @default(false) @map("pertenece_junta_directiva")
  puestoJuntaDirectiva    String?             @map("puesto_junta_directiva") @db.VarChar(50)
  estado                  Int                 @default(1) @db.SmallInt
  createdAt               DateTime?           @default(now()) @map("created_at")
  updatedAt               DateTime?           @default(now()) @updatedAt @map("updated_at")
  fechaInactivo           DateTime?           @map("fecha_inactivo")
  observaciones           String?
  asistencias             Asistencia[]
  reportes                ReporteAsistencia[]
  asistenciasActaAsociacion AsistenciaActaAsociacion[]
  asistenciasActaJD       AsistenciaActaJD[]

  @@map("asociados")
}

model ActaAsociacion {
  id            Int                        @id @default(autoincrement())
  fecha         DateTime                   @db.Date
  tipoSesion    String                     @map("tipo_sesion") @db.VarChar(20)
  urlActa       String?                    @map("url_acta")
  nombreArchivo String?                    @map("nombre_archivo") @db.VarChar(255)
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @default(now()) @updatedAt @map("updated_at")
  asistencias   AsistenciaActaAsociacion[]

  @@map("actas_asociacion")
}

model AsistenciaActaAsociacion {
  id            Int              @id @default(autoincrement())
  actaId        Int              @map("acta_id")
  asociadoId    Int              @map("asociado_id")
  estado        EstadoAsistencia @default(ausente)
  justificacion String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at")
  acta          ActaAsociacion   @relation(fields: [actaId], references: [id], onDelete: Cascade)
  asociado      Asociado         @relation(fields: [asociadoId], references: [id], onDelete: Cascade)

  @@unique([actaId, asociadoId])
  @@map("asistencias_acta_asociacion")
}

model ActaJuntaDirectiva {
  id            Int                @id @default(autoincrement())
  fecha         DateTime           @db.Date
  tipoSesion    String             @map("tipo_sesion") @db.VarChar(20)
  urlActa       String?            @map("url_acta")
  nombreArchivo String?            @map("nombre_archivo") @db.VarChar(255)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @default(now()) @updatedAt @map("updated_at")
  asistencias   AsistenciaActaJD[]

  @@map("actas_junta_directiva")
}

model AsistenciaActaJD {
  id            Int                @id @default(autoincrement())
  actaId        Int                @map("acta_id")
  asociadoId    Int                @map("asociado_id")
  estado        EstadoAsistencia   @default(ausente)
  justificacion String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @default(now()) @updatedAt @map("updated_at")
  acta          ActaJuntaDirectiva @relation(fields: [actaId], references: [id], onDelete: Cascade)
  asociado      Asociado           @relation(fields: [asociadoId], references: [id], onDelete: Cascade)

  @@unique([actaId, asociadoId])
  @@map("asistencias_acta_jd")
}

model Empleado {
  id             Int             @id @default(autoincrement())
  nombre         String          @db.VarChar(100)
  cedula         String          @unique @db.VarChar(20)
  puesto         String          @db.VarChar(100)
  salarioBase    Decimal         @map("salario_base") @db.Decimal(12, 2)
  cuentaBancaria String?         @map("cuenta_bancaria") @db.VarChar(50)
  estado         Int             @default(1) @db.SmallInt
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")
  lineasPlanilla LineaPlanilla[]

  @@map("empleados")
}

model PeriodoPlanilla {
  id              Int             @id @default(autoincrement())
  mes             Int
  anio            Int
  estado          String          @default("borrador") @db.VarChar(20)
  fechaGeneracion DateTime        @default(now()) @map("fecha_generacion")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at")
  lineas          LineaPlanilla[]

  @@unique([mes, anio])
  @@map("periodos_planilla")
}

model LineaPlanilla {
  id                Int             @id @default(autoincrement())
  empleadoId        Int             @map("empleado_id")
  periodoPlanillaId Int             @map("periodo_planilla_id")
  diasTrabajados    Int             @map("dias_trabajados")
  diasAusentes      Int             @default(0) @map("dias_ausentes")
  diasVacaciones    Int             @default(0) @map("dias_vacaciones")
  diasIncapacidad   Int             @default(0) @map("dias_incapacidad")
  montoAPagar       Decimal         @map("monto_a_pagar") @db.Decimal(12, 2)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at")
  empleado          Empleado        @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  periodo           PeriodoPlanilla @relation(fields: [periodoPlanillaId], references: [id], onDelete: Cascade)

  @@unique([empleadoId, periodoPlanillaId])
  @@map("lineas_planilla")
}

model Evento {
  id          Int                 @id @default(autoincrement())
  nombre      String              @db.VarChar(255)
  descripcion String?
  fecha       DateTime            @db.Date
  hora        DateTime            @db.Time(6)
  activo      Boolean             @default(true)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @default(now()) @updatedAt @map("updated_at")
  asistencias Asistencia[]
  reportes    ReporteAsistencia[]

  @@map("eventos")
}

model Asistencia {
  id            Int              @id @default(autoincrement())
  asociadoId    Int              @map("asociado_id")
  eventoId      Int              @map("evento_id")
  fechaRegistro DateTime         @default(now()) @map("fecha_registro")
  observaciones String?
  estado        EstadoAsistencia @default(ausente)
  horaRegistro  DateTime         @default(now()) @map("hora_registro") @db.Time(6)
  justificacion String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at")
  asociado      Asociado         @relation(fields: [asociadoId], references: [id], onDelete: Cascade)
  evento        Evento           @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@unique([asociadoId, eventoId])
  @@map("asistencias")
}

model ReporteAsistencia {
  id            Int              @id @default(autoincrement())
  asociadoId    Int?             @map("asociado_id")
  eventoId      Int              @map("evento_id")
  fecha         DateTime         @db.Date
  estado        EstadoAsistencia
  horaRegistro  DateTime?        @map("hora_registro") @db.Time(6)
  observaciones String?
  justificacion String?
  createdAt     DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  congregadoId  Int?             @map("congregado_id")
  asociado      Asociado?        @relation(fields: [asociadoId], references: [id], onDelete: Cascade)
  congregado    Congregado?      @relation(fields: [congregadoId], references: [id], onDelete: Cascade)
  evento        Evento           @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@unique([asociadoId, eventoId, fecha])
  @@unique([congregadoId, eventoId, fecha])
  @@map("reportes_asistencia")
}

model Permiso {
  id                      Int      @id @default(autoincrement())
  usuarioId               Int      @map("usuario_id")
  fechaInicio             DateTime @map("fecha_inicio") @db.Date
  fechaFin                DateTime @map("fecha_fin") @db.Date
  motivo                  String
  documentoUrl            String?  @map("documento_url")
  estado                  String   @default("PENDIENTE") @db.VarChar(20)
  observacionesResolucion String?  @map("observaciones_resolucion")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at")
  usuario                 Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("permisos")
}

enum EstadoAsistencia {
  presente
  ausente
  justificado
}

model Auditoria {
  id         Int      @id @default(autoincrement())
  tabla      String   @db.VarChar(50)
  registroId Int      @map("registro_id")
  accion     String   @db.VarChar(20)
  detalles   String?
  fecha      DateTime @default(now())
  usuarioId  Int?     @map("usuario_id")

  @@map("auditoria")
}
